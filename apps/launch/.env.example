# Soul Good launch microsite — environment variables.
#
# Lead capture writes to MongoDB (via Mongoose) when MONGODB_URI is set.
# Otherwise it falls back to the local JSONL file at
# apps/launch/public/leads.local.jsonl (gitignored). On any MongoDB error the
# route also falls back to the local file so a lead is never dropped.
#
# Copy this file to .env.local and fill in real values. Never commit .env.local.

# MongoDB connection string (Atlas SRV URI). Leads are stored in the `leads`
# collection of the database named in the URI's path (defaults to `test` if the
# URI has no database segment — add one, e.g. .../soulgood?retryWrites=true...).
MONGODB_URI=

# Stripe — powers the first-week order ($88 intro) via Stripe Checkout (hosted page).
# When STRIPE_SECRET_KEY is blank, the payment step is SKIPPED: the order action
# still captures the lead and routes the guest to /welcome (the order is recorded),
# and /api/checkout returns { url: null, disabled: true } instead of erroring.
# STRIPE_PUBLISHABLE_KEY is unused for pure hosted Checkout but documented for
# future client-side use.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
