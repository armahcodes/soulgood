# Soul Good launch microsite — environment variables.
#
# Lead capture uses Airtable ONLY when ALL THREE of these are set. Otherwise it
# falls back to the local JSONL file at apps/launch/public/leads.local.jsonl
# (gitignored). On any Airtable error the route also falls back to the local file
# so a lead is never dropped.
#
# Copy this file to .env.local and fill in real values when the founder provides
# an Airtable key. Never commit .env.local.

AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_NAME=

# Stripe — powers the first-week order ($88 intro) via Stripe Checkout (hosted page).
# When STRIPE_SECRET_KEY is blank, the payment step is SKIPPED: the order action
# still captures the lead and routes the guest to /welcome (the order is recorded),
# and /api/checkout returns { url: null, disabled: true } instead of erroring.
# STRIPE_PUBLISHABLE_KEY is unused for pure hosted Checkout but documented for
# future client-side use.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Expected Airtable table columns (create these fields in the table named by
# AIRTABLE_TABLE_NAME so the adapter's mapping lands cleanly):
#   Email        (Single line text)   <- lead.email
#   Phone        (Single line text)   <- lead.phone
#   Name         (Single line text)   <- lead.name
#   Pathway      (Single line text)   <- mindful | performance | detox | alignment
#   Intent       (Single line text)   <- buyer | list
#   Dietary      (Single line text)   <- comma-separated lifestyles
#   Allergens    (Single line text)   <- comma-separated allergens
#   Foods        (Single line text)   <- comma-separated foods to enjoy
#   Priorities   (Single line text)   <- comma-separated "what matters most"
#   Body Needs   (Single line text)   <- reflection: body
#   Soul Needs   (Single line text)   <- reflection: soul
#   Captured At  (Single line text)   <- ISO timestamp (server-set)
#   Local Id     (Single line text)   <- generated capture id
